<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MasqatGate</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="site-header sticky-top bg-white shadow-sm">
        <nav class="navbar navbar-expand-lg navbar-light bg-white py-3">
            <div class="container">
                <a class="navbar-brand fw-bold text-uppercase d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <img src="/image/logo.png" alt="Muscat Gates Logo" height="40">
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav mx-auto gap-lg-3">
                        <li class="nav-item"><a class="nav-link" href="https://muscatgates.com/">Home</a></li>
                        <li class="nav-item"><a class="nav-link" href="https://muscatgates.com/for-sale/">For Sale</a></li>
                        <li class="nav-item"><a class="nav-link" href="https://muscatgates.com/for-rent/">For Rent</a></li>
                        <li class="nav-item"><a class="nav-link" href="https://muscatgates.com/about-us/">About Us</a></li>
                        <li class="nav-item"><a class="nav-link" href="https://muscatgates.com/contact-us/">Contact</a></li>
                    </ul>
                    <a class="btn btn-dark px-4" href="https://muscatgates.com/contact-us/">Get In Touch</a>
                </div>
            </div>
        </nav>
    </header>

    <main id="main-content">
        @RenderBody()
    </main>

    <footer class="footer-section mt-5 py-5 bg-dark text-light" id="contact">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <h5 class="fw-bold mb-3">Muscat Gates</h5>
                    <p class="text-light-emphasis">Muscat Gates is a real estate listing platform in Oman that connects property seekers with trusted real estate agencies. Our goal is to simplify property search and help agencies promote their listings to the right audience.</p>
                    <a href="https://muscatgates.com/contact-us/" class="btn btn-outline-light btn-sm mt-2">Get In Touch</a>
                </div>
                <div class="col-lg-2">
                    <h6 class="fw-bold mb-3">Main Menu</h6>
                    <ul class="list-unstyled footer-links">
                        <li><a href="https://muscatgates.com/for-sale/">For Sale</a></li>
                        <li><a href="https://muscatgates.com/for-rent/">For Rent</a></li>
                        <li><a href="https://muscatgates.com/about-us/">About Us</a></li>
                        <li><a href="https://muscatgates.com/contact-us/">Contact</a></li>
                    </ul>
                </div>
                <div class="col-lg-3">
                    <h6 class="fw-bold mb-3">Contact Information</h6>
                    <p class="mb-1">Tathmeer Building, 23 July Street, Muscat, Oman</p>
                    <p class="mb-1"><a href="https://api.whatsapp.com/send?phone=96892316300" class="text-light text-decoration-none">+968 923 163 00</a></p>
                </div>
                <div class="col-lg-3">
                    <h6 class="fw-bold mb-3">Follow Us</h6>
                    <div class="d-flex gap-2 footer-socials">
                        <a href="#" class="social-circle"><i class="fa-brands fa-facebook-f"></i></a>
                        <a href="#" class="social-circle"><i class="fa-brands fa-instagram"></i></a>
                        <a href="#" class="social-circle"><i class="fa-brands fa-linkedin-in"></i></a>
                        <a href="#" class="social-circle"><i class="fa-brands fa-youtube"></i></a>
                    </div>
                </div>
            </div>
            <hr class="border-secondary my-4" />
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
                <small>© 2026 Powered by Muscat Gates</small>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
